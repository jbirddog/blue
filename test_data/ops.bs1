
#
# op - tested
#
# 00 - y
# 01 - y
# 02 - y
# 03 - y
# 04 - y
# 05 - y
# 06 - y
# 07 - y
# 08 - y
# 09 - y
# 0A - y
# 0B - y
# 0C - y
# 0D - y
# 0E - y
# 0F - y
# 10 - y
#

#
# modes
#

# set to compile, back to interpret
0F 10

#
# code buffer address
#

# push addr of code buffer start and set here
0A 05

# push addr of code buffer here and set here
04 05

#
# read from input/write to code buffer
#

# push addr of code buffer
04

# read/write a byte
00 48 06

# read/write a word
01 31 C0 07

# read/write a dword
02 95 00 40 00 08

# read/write a qword
03 7f45 4c46 0201 0103 09

# drop the addr on the stack
0D

#
# stack ops
#

# push two values, subtract them, drop result
00 03
00 01
0B 0D

# push two values, add them, drop the result
00 07
00 00
0C 0D

# push two values, swap them, drop them
00 07
00 10
0E 0D 0D
