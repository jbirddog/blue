bd = build

rule cc
  depfile = $out.d
  command = cc -std=c2x -Wall -Wpedantic -MD -MF $out.d -o $out -c $in

rule link
  command = cc -o $out $in

build ${bd}/main.o: cc main.c
build ${bd}/frontend.o: cc frontend.c
build ${bd}/backend.o: cc backend.c

build ${bd}/blue: link ${bd}/main.o ${bd}/frontend.o ${bd}/backend.o
